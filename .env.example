# ═══════════════════════════════════════════════════
# D8X — Agentic SDLC Platform
# ═══════════════════════════════════════════════════

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://sdlc:sdlc_password@localhost:5432/agentic_sdlc
DATABASE_URL_SYNC=postgresql://sdlc:sdlc_password@localhost:5432/agentic_sdlc

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── Object Storage (MinIO) ───
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agentic-sdlc-artifacts

# ─── LLM Providers ───
LLM_PROVIDER=google

GOOGLE_AI_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=ollama

# Per-agent LLM overrides (optional)
# INGEST_LLM_PROVIDER=groq
# DISCOVER_LLM_PROVIDER=google
# DESIGN_LLM_PROVIDER=google

# ─── GitHub ───
GITHUB_TOKEN=
GITHUB_OWNER=

# ─── LangSmith (Observability) ───
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-sdlc

# ─── App Config ───
APP_ENV=development
LOG_LEVEL=DEBUG
